# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# LLM Configuration
LLM_PROVIDER=openrouter  # "openrouter" or "ollama"

# OpenRouter Configuration (Recommended - Free models available)
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=nvidia/llama-3.1-nemotron-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=120  # Request timeout in seconds (default: 120)
OPENROUTER_MAX_RETRIES=3  # Number of retry attempts (default: 3)

# Ollama Configuration (Fallback - Local models)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Storage
DATA_DIR=./data
UPLOAD_DIR=./data/raw
PROCESSED_DIR=./data/processed

# Extraction Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MIN_CONFIDENCE=0.7

# Language Settings
SPACY_MODELS=fr_core_news_lg,en_core_web_lg
SUPPORTED_LANGUAGES=fr,ar,en

# Logging
LOG_LEVEL=TRACE  # Options: TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/app.log

# Use TRACE for detailed LLM debugging (shows prompts, responses, timing)
# LOG_LEVEL=TRACE
